<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="SauceLab - UI Automation Test" verbose="1" >
    <listeners>
        <listener class-name="core.MethodListener"></listener>
    </listeners>
    <parameter name="appUrl" value="https://www.saucedemo.com/"></parameter>

    <test name="Run on Firefox browser" >
        <parameter name="browser" value="firefox"></parameter>
        <classes>
            <class name="com.saucelab.Level_24_Sort" />
        </classes>
    </test>
</suite>